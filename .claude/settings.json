{
  "permissions": {
    "allow": [
      "mcp__codegraph__codegraph_status",
      "mcp__codegraph__codegraph_search",
      "mcp__codegraph__codegraph_node",
      "mcp__codegraph__codegraph_context",
      "mcp__codegraph__codegraph_callers",
      "mcp__codegraph__codegraph_callees",
      "mcp__codegraph__codegraph_impact",
      "mcp__codegraph__codegraph_files",
      "mcp__codegraph__codegraph_list_pages",
      "mcp__chrome-devtools__list_console_messages",
      "mcp__chrome-devtools__list_network_requests",
      "mcp__chrome-devtools__get_console_message",
      "mcp__chrome-devtools__get_network_request",
      "mcp__chrome-devtools__take_screenshot",
      "mcp__chrome-devtools__take_snapshot",
      "mcp__chrome-devtools__select_page",
      "mcp__chrome-devtools__wait_for",
      "Bash(awk *)",
      "Bash(pdftotext *)",
      "Bash(rtk gain*)",
      "Bash(rtk --version)"
    ],
    "deny": [
      "Bash(git push * master)",
      "Bash(git push * develop)",
      "Bash(git push * main)",
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(/usr/bin/sudo *)",
      "Bash(doas *)",
      "Bash(chmod *)",
      "Bash(chmod 777 *)",
      "Bash(chmod -R 777 *)",
      "Bash(mkdir *)",
      "Bash(dd if *)",
      "Bash(crontab *)",
      "Bash(nc -l *)",
      "Bash(cat *)",
      "Bash(socat *)",
      "Bash(wget *)",
      "Bash(curl | python3 *)",
      "Bash(curl | sh *)",
      "Bash(curl | bash *)",
      "Write(/etc/*)",
      "Write(/usr/*)",
      "Write(/System/*)",
      "Write(/var/*)",
      "Write(/bin/*)",
      "Write(/sbin/*)",
      "Write(~/.ssh/*)",
      "Write(*.pem)",
      "Write(*id_rsa*)",
      "Write(*id_ed25519*)",
      "Write(*.key*)",
      "Write(*credentials*)",
      "Write(*secrets*)",
      "Edit(~/.ssh/*)",
      "Edit(*.pem)",
      "Edit(*id_rsa*)",
      "Edit(*id_ed25519*)",
      "Edit(*credentials*)",
      "Edit(*secrets*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      },
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/plugins/jc/hooks/block-git-commit-protected.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ${CLAUDE_PROJECT_DIR}/plugins/jc/statusline-command.sh"
  },
  "enabledPlugins": {
    "caveman@caveman": true,
    "typescript-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "playground@claude-plugins-official": true,
    "hookify@claude-code-plugins": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "claude-code-plugins": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-code"
      }
    }
  }
}
